FROM alpine:3.20

RUN apk add --no-cache postgresql16-client rclone bash curl

COPY infra/backup/backup.sh /usr/local/bin/backup.sh
COPY infra/backup/restore.sh /usr/local/bin/restore.sh
COPY infra/postgres/wal_to_s3.sh /usr/local/bin/wal_to_s3.sh
RUN chmod +x /usr/local/bin/backup.sh /usr/local/bin/restore.sh /usr/local/bin/wal_to_s3.sh

CMD ["crond", "-f"]
